generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

// Multi-tenant: Organization (Temple Trust)
model Organization {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String?
  logo          String?
  config        Json?     // Theme, settings, etc.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  temples           Temple[]
  users             User[]
  applications      TempleApplication[]
  userOrganizations UserOrganization[]
  dailyWisdoms      DailyWisdom[]
}

// Temple (can have multiple per organization)
model Temple {
  id            String    @id @default(cuid())
  name          String
  nameHi        String?
  slug          String    @unique
  description   String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  website       String?
  logo          String?
  images        String[]
  primaryColor  String?
  secondaryColor String?
  config        Json?     // Temple-specific settings
  isActive      Boolean   @default(true)
  isPremium     Boolean   @default(false)
  featuredUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscriptionPlan     String    @default("basic")
  subscriptionStatus   String    @default("active")
  subscriptionEndDate  DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  poojas          Pooja[]
  bookings        Booking[]
  events          Event[]
  visits          Visit[]
  donations       Donation[]
  commissionConfig CommissionConfig?
  subscription    TempleSubscription?
  payouts         Payout[]
  applications    TempleApplication[]
  userBadges      UserBadge[]
  userStreaks     UserStreak[]
  leaderboards    Leaderboard[]
  sosAlerts       SosAlert[]
  lostFoundItems  LostFoundItem[]
  apiKeys         ApiKey[]
  cashEntries     CashEntry[]
  opsChecklists   OpsChecklistLog[]
}

// Users (Devotees, Admins, Trustees)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  password      String?   // Hashed password for credentials auth (optional for Google auth)
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(DEVOTEE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  donations     Donation[]
  bookings      Booking[]
  userBadges    UserBadge[]
  userStreaks   UserStreak[]
  leaderboards  Leaderboard[]
  visits        Visit[]
  sosAlerts     SosAlert[]
  lostFoundItems LostFoundItem[]
  notificationPreference NotificationPreference?
  userOrganizations UserOrganization[]
  cashEntries   CashEntry[]
  opsChecklists OpsChecklistLog[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

enum UserRole {
  DEVOTEE
  ADMIN
  TRUSTEE
  SUPER_ADMIN
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("DEVOTEE")
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Platform fee configuration per temple
model CommissionConfig {
  id                  String    @id @default(cuid())
  platformFee         Decimal   @default(0.00)   // Fixed monthly platform fee
  premiumListingFee   Decimal   @default(0.00)   // Monthly premium listing fee
  premiumListingActive Boolean  @default(false)

  templeId            String    @unique
  temple              Temple    @relation(fields: [templeId], references: [id])

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Temple subscription billing
model TempleSubscription {
  id                  String    @id @default(cuid())
  plan                String    @default("FREE") // FREE, BASIC, PREMIUM
  platformFee         Decimal   @default(0.00)
  billingCycle        String    @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  startDate           DateTime  @default(now())
  endDate             DateTime?
  autoRenew           Boolean   @default(true)
  status              String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  paymentMethod       String?
  lastPaidAt          DateTime?
  nextBillingAt       DateTime?
  razorpaySubscriptionId String?

  templeId            String    @unique
  temple              Temple    @relation(fields: [templeId], references: [id])

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Payouts to temples
model Payout {
  id            String    @id @default(cuid())
  amount        Decimal   @db.Decimal(10, 2)
  periodStart   DateTime
  periodEnd     DateTime
  status        PayoutStatus @default(PENDING)

  // Bank details at time of payout
  bankAccountNo String?
  bankIfsc      String?
  bankName      String?
  accountHolder String?

  transactionRef String?
  processedAt   DateTime?
  processedBy   String?
  notes         String?

  templeId      String
  temple        Temple    @relation(fields: [templeId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Temple onboarding application
model TempleApplication {
  id            String    @id @default(cuid())
  templeName    String
  templeSlug    String    @unique
  description   String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  website       String?

  contactName   String
  contactPhone  String
  contactEmail  String?

  bankAccountNo String?
  bankIfsc      String?
  bankName      String?
  accountHolder String?

  trustName     String?
  trustRegNo    String?
  trustDoc      String?

  status        ApplicationStatus @default(PENDING)
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  templeId      String?
  temple        Temple?   @relation(fields: [templeId], references: [id])
}

// Poojas (Rituals available for booking)
model Pooja {
  id            String    @id @default(cuid())
  name          String
  nameHi        String    // Hindi name
  description   String?
  descriptionHi String?
  duration      Int       // Duration in minutes
  price         Decimal   @db.Decimal(10, 2)
  /// Max concurrent bookings per time slot (festival capacity)
  maxPerSlot    Int       @default(20)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  templeId      String
  temple        Temple    @relation(fields: [templeId], references: [id])

  bookings      Booking[]
}

// Bookings (Pooja reservations)
model Booking {
  id            String    @id @default(cuid())
  date          DateTime  // Pooja date
  time          String    // Time slot (e.g., "06:00-07:00")
  status        BookingStatus @default(PENDING)
  totalAmount   Decimal   @db.Decimal(10, 2)
  orderId       String?
  paymentId     String?

  // Temple-grade devotee details (why real mandirs book software)
  devoteeName   String?
  gotra         String?
  nakshatra     String?
  sankalp       String?
  phone         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Optional for guest / counter-assisted bookings
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])

  poojaId       String
  pooja         Pooja     @relation(fields: [poojaId], references: [id])

  templeId      String
  temple        Temple    @relation(fields: [templeId], references: [id])

  @@index([templeId, date, time])
  @@index([poojaId, date, time])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// Donations
model Donation {
  id            String    @id @default(cuid())
  amount        Decimal   @db.Decimal(10, 2)
  currency      String    @default("INR")
  purpose       String?   // Specific purpose of donation
  paymentId     String?   // Razorpay payment ID
  orderId       String?   // Razorpay order ID
  status        DonationStatus @default(PENDING)

  // Trust layer / 80G-ready fields
  donorName     String?
  donorEmail    String?
  donorPhone    String?
  panNumber     String?
  want80G       Boolean   @default(false)
  receiptNumber String?   @unique

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Optional for guest (mass-market) donations
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])

  templeId      String?
  temple        Temple?   @relation(fields: [templeId], references: [id])

  @@index([templeId, status])
  @@index([panNumber])
  @@index([createdAt])
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Events (Festivals, Aartis, etc.)
model Event {
  id            String    @id @default(cuid())
  title         String
  titleHi       String?
  description   String?
  descriptionHi String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  imageUrl      String?
  isRecurring   Boolean   @default(false)
  recurrenceRule String?  // iCal RRULE format
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  templeId      String
  temple        Temple    @relation(fields: [templeId], references: [id])
}

// Live Devotee Counter
model Counter {
  id            String    @id @default(cuid())
  name          String    @unique
  value         Int       @default(0)
  lastUpdated   DateTime  @updatedAt
}

// Gamification Models
model Badge {
  id            String    @id @default(cuid())
  name          String    @unique
  nameHi        String
  description   String?
  icon          String
  tier          BadgeTier @default(BRONZE)
  createdAt     DateTime  @default(now())

  userBadges    UserBadge[]
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model UserBadge {
  id            String    @id @default(cuid())
  earnedAt      DateTime  @default(now())

  templeId  String?
  temple    Temple?  @relation(fields: [templeId], references: [id])

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  badgeId       String
  badge         Badge     @relation(fields: [badgeId], references: [id])

  @@index([templeId])
  @@unique([userId, badgeId])
}

model UserStreak {
  id            String    @id @default(cuid())
  type          String    // "darshan", "donation", "booking"
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActive    DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  templeId  String?
  temple    Temple?  @relation(fields: [templeId], references: [id])

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([templeId])
  @@unique([userId, type])
}

model Leaderboard {
  id            String    @id @default(cuid())
  period        String    // "weekly", "monthly", "alltime"
  score         Int       @default(0)
  rank          Int?
  updatedAt     DateTime  @updatedAt

  templeId  String?
  temple    Temple?  @relation(fields: [templeId], references: [id])

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([templeId])
  @@unique([userId, period])
}

model NotificationPreference {
  id            String    @id @default(cuid())
  dailyWisdom   Boolean   @default(true)
  eventAlerts   Boolean   @default(true)
  streakRemind  Boolean   @default(true)
  quietStart    String    @default("22:00")
  quietEnd      String    @default("06:00")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
}

model DailyWisdom {
  id            String        @id @default(cuid())
  verse         String
  verseHi       String
  source        String
  audioUrl      String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt     DateTime      @default(now())
}

// Temple Visit Check-ins
model Visit {
  id            String    @id @default(cuid())
  checkInTime   DateTime  @default(now())
  checkOutTime  DateTime?
  duration      Int?      // Duration in minutes
  createdAt     DateTime  @default(now())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  templeId      String?
  temple        Temple?   @relation(fields: [templeId], references: [id])
}

// Smart Pilgrim Services: Emergency SOS alerts
model SosAlert {
  id        String   @id @default(cuid())
  userId    String
  templeId  String
  type      String   @default("MEDICAL")
  location  String   @default("")
  message   String   @default("")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  temple Temple @relation(fields: [templeId], references: [id])

  @@index([templeId])
  @@index([status])
}

// Smart Pilgrim Services: Lost & Found items
model LostFoundItem {
  id          String   @id @default(cuid())
  userId      String
  templeId    String
  type        String   @default("LOST")   // LOST or FOUND
  description String
  location    String   @default("")
  contactInfo String   @default("")
  status      String   @default("OPEN")   // OPEN, RESOLVED, CLOSED
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  temple Temple @relation(fields: [templeId], references: [id])

  @@index([templeId])
  @@index([type])
  @@index([status])
}

model ApiKey {
  id          String   @id @default(cuid())
  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  name        String
  key         String   @unique
  scopes      String   @default("read")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  @@index([templeId])
  @@index([key])
}

// Phone OTP for Bharat-first auth
model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, consumed])
  @@index([expiresAt])
}

// Hundi / counter cash (offline collections)
model CashEntry {
  id          String   @id @default(cuid())
  type        String   @default("HUNDI") // HUNDI, COUNTER, PRASAD, OTHER
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("INR")
  note        String?
  collectedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id])
  recordedById String?
  recordedBy  User?    @relation(fields: [recordedById], references: [id])

  @@index([templeId, collectedAt])
  @@index([type])
}

// Daily trustee ops checklist completion
model OpsChecklistLog {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  items       Json     // { openAarti: true, countHundi: true, ... }
  notes       String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([templeId, date])
  @@index([templeId])
}
